{
    "$schema": "https://raw.githubusercontent.com/DavidAnson/markdownlint-cli2/main/schema/markdownlint-cli2-config-schema.json",
    "config": {
        // Line length (80) is impractical for prose + tables + file:line refs.
        "MD013": false
    },
    "ignores": [
        "./docs/api/**/*",
        "./docs/content/api/**/*",
        ".github/**/*"
    ],
    "gitignore": true
}